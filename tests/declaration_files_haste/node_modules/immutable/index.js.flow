declare export class List<+T> {
  static <T>(iter?: ?ReadonlyArray<T>): List<T>;
  get(index: number): T | void;
  size: number;
  push(...values: Array<T>): List<T>;
  filter(predicate: (value: T) => mixed): List<T>;
  toArray(): Array<T>;
}

declare export class Map<K, +V> {
  get(key: K): V | void;
}

declare export function Record<T>(value: T): Class<any>;

export default {
  List,
  Map,
  Record,
};
