[ignore]

[include]

[libs]
globals.js

[options]
casting_syntax=as
module.system=haste
module.system.haste.paths.excludes=<PROJECT_ROOT>/external/.*
module.system.haste.paths.excludes=<PROJECT_ROOT>/foo/.*
module.system.haste.paths.excludes=<PROJECT_ROOT>/ws/.*
module.system.haste.paths.excludes=<PROJECT_ROOT>/node_modules/qux/.*
all=true
