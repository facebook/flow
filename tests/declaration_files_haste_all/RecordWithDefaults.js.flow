declare class RecordWithDefaultsBase {
  label: string;
  note: ?string;

  constructor(
    value?: {|
      readonly label?: string,
      readonly note?: ?string,
    |},
  ): void;

  get(key: 'label'): string;
  get(key: 'note'): ?string;

  set(key: 'label', value: string): this;
  set(key: 'note', value: ?string): this;

  merge(
    value: {|
      readonly label?: string,
      readonly note?: ?string,
    |},
  ): this;
}

declare class RecordWithDefaults extends RecordWithDefaultsBase {}

export default RecordWithDefaults;
