    declare hook useEffect(
      create: () => MaybeCleanUpFn,
      inputs?: ?ReadonlyArray<unknown>,
    ): void;

    declare const experimental_useEffectEvent: hook <
      F extends (...empty) => unknown,
    >(
      callback: F,
