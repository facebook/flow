      initialState: Awaited<State>,
      permalink?: string,
    ): [
      state: Awaited<State>,
      dispatch: (payload: Payload) => void,
      isPending: boolean,
    ];

    type ComponentType<in P extends {...}> = component(...P);
    // type AbstractComponent intentionally removed.
    // Use [component types](https://flow.org/en/docs/react/component-types/) instead.

    type PropsOf<
      C extends
        string | React.MixedElement | React$RendersExactly<React.ElementType>,
