    type ElementRef<C> = globalThis.React.ElementRef<C>;

    type ChildrenArray<out T> = ReadonlyArray<ChildrenArray<T>> | T;
    type ReactSetStateFunction<S> = ((S => S) | S) => void;
    type RefObject<T> = globalThis.React.RefObject<T>;
    type Interaction = {
      name: string,
      timestamp: number,
      ...
