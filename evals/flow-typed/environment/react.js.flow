    type MixedElement = globalThis.React.MixedElement;
    type ElementType = globalThis.React.ElementType;

    type Key = globalThis.React.Key;
    type RefSetter<in T> = globalThis.React.RefSetter<T>;
    type Node = globalThis.React.Node;
    type Context<T> = globalThis.React.Context<T>;
    type Portal = globalThis.React.Portal;

